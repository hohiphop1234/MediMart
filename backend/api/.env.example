PORT=3000

# Get these from Supabase Dashboard > Connect. Never put this file in source control with real values.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Server only: use the new secret key, or the legacy service_role key if your project still exposes it.
# Never expose this value to Android or commit it to Git.
SUPABASE_SECRET_KEY=sb_secret_your_server_only_key

# Local development only. This path is disabled whenever NODE_ENV=production.
# It accepts only the configured test email and still creates a normal Supabase session.
ENABLE_DEV_OTP=false
DEV_OTP_TEST_EMAIL=dev@example.com
DEV_OTP_CODE=123456
DEV_OTP_TEST_PASSWORD=replace-with-a-long-local-only-password
